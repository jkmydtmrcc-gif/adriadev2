    "cors": "^2.8.5",
    "dotenv": "^16.4.0",
    "express": "^4.21.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.0",
    "nodemon": "^3.1.0",
    "pdfkit": "^0.15.0"
  }
